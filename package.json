{
  "name": "hudhuria",
  "version": "1.0.0",
  "private": true,
  "description": "Hudhuria — Campus Event Booking & Management Platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "yarn workspace @hudhuria/mobile start --web --clear",
    "backend": "yarn workspace @hudhuria/backend dev",
    "db:seed": "yarn workspace @hudhuria/backend db:seed",
    "db:reset": "yarn workspace @hudhuria/backend db:reset",
    "db:migrate": "yarn workspace @hudhuria/backend db:migrate",
    "db:studio": "yarn workspace @hudhuria/backend db:studio",
    "test": "yarn workspace @hudhuria/backend test"
  },
  "packageManager": "yarn@4.2.2",
  "devDependencies": {
    "esbuild": "0.27.4"
  }
}
